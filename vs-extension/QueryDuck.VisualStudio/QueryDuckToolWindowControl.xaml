<UserControl x:Class="QueryDuck.VisualStudio.QueryDuckToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:QueryDuck.VisualStudio"
             Background="#FF2B2D30">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,4">
            <Button x:Name="RefreshButton" Content="Refresh" Width="72" Margin="0,0,8,4" Click="RefreshButton_Click" />
            <Button x:Name="ClearButton" Content="Clear" Width="64" Margin="0,0,8,4" Click="ClearButton_Click" />
            <CheckBox x:Name="AutoRefreshCheckBox" Content="Auto-refresh" IsChecked="True" VerticalAlignment="Center" Margin="0,0,8,4" />
            <CheckBox x:Name="FollowLatestCheckBox" Content="Follow latest" IsChecked="True" VerticalAlignment="Center" Margin="0,0,8,4" />
            <TextBlock Text="Server" VerticalAlignment="Center" Margin="0,0,4,4" Foreground="#FFDDE4F0" />
            <TextBox x:Name="ServerUrlTextBox" Width="180" Margin="0,0,8,4" Text="http://127.0.0.1:17654" />
            <Button x:Name="ConnectButton" Content="Connect" Width="72" Margin="0,0,8,4" Click="ConnectButton_Click" />
            <TextBlock Text="Provider" VerticalAlignment="Center" Margin="0,0,4,4" Foreground="#FFDDE4F0" />
            <ComboBox x:Name="ProviderFilterComboBox" Width="120" Margin="0,0,8,4" SelectionChanged="FilterChanged">
                <ComboBoxItem Content="All providers" IsSelected="True" />
                <ComboBoxItem Content="Oracle" />
                <ComboBoxItem Content="PostgreSql" />
                <ComboBoxItem Content="SqlServer" />
                <ComboBoxItem Content="MySql" />
            </ComboBox>
            <TextBlock Text="Tag" VerticalAlignment="Center" Margin="0,0,4,4" Foreground="#FFDDE4F0" />
            <TextBox x:Name="TagFilterTextBox" Width="100" Margin="0,0,8,4" TextChanged="FilterChanged" />
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Margin="8,0,0,4" Foreground="#FFE05555" Text="Disconnected" />
        </WrapPanel>

        <TextBlock x:Name="SessionWarningsLabel"
                   Grid.Row="1"
                   Margin="8,0,8,4"
                   Foreground="#FFE8A035"
                   TextWrapping="Wrap" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="280" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="3*" MinWidth="360" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Captured queries" Foreground="#FFDDE4F0" BorderBrush="#FF454545">
                <DataGrid x:Name="EventsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          Background="#FF1E1F22"
                          Foreground="#FFDDE4F0"
                          BorderThickness="0"
                          SelectionChanged="EventsGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding FormattedTime}" Width="72" />
                        <DataGridTextColumn Header="Provider" Binding="{Binding Provider}" Width="84" />
                        <DataGridTextColumn Header="Tag" Binding="{Binding TagDisplay}" Width="90" />
                        <DataGridTextColumn Header="Warn" Binding="{Binding WarningCount}" Width="44" />
                        <DataGridTextColumn Header="Ms" Binding="{Binding FormattedDuration}" Width="52" />
                        <DataGridTextColumn Header="SQL" Binding="{Binding SqlPreview}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#FF454545" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="MetaLabel" Grid.Row="0" Margin="8,4" Foreground="#FF8FA2C3" TextWrapping="Wrap" />
                <TabControl x:Name="DetailTabs" Grid.Row="1" Background="#FF2B2D30" Foreground="#FFDDE4F0">
                    <TabItem Header="SQL">
                        <TextBox x:Name="SqlTextBox" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 Background="#FF1E1F22" Foreground="#FFDDE4F0" BorderThickness="0" FontFamily="Consolas" />
                    </TabItem>
                    <TabItem Header="Expression Tree">
                        <TreeView x:Name="ExpressionTreeView" Background="#FF1E1F22" Foreground="#FFDDE4F0" BorderThickness="0" />
                    </TabItem>
                    <TabItem Header="C# Expression">
                        <TextBox x:Name="CSharpTextBox" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 Background="#FF1E1F22" Foreground="#FFDDE4F0" BorderThickness="0" FontFamily="Consolas" />
                    </TabItem>
                    <TabItem Header="Diagnostics">
                        <ListBox x:Name="DiagnosticsListBox" Background="#FF1E1F22" Foreground="#FFDDE4F0" BorderThickness="0" />
                    </TabItem>
                    <TabItem Header="Parameters">
                        <DataGrid x:Name="ParametersGrid"
                                  AutoGenerateColumns="True"
                                  IsReadOnly="True"
                                  Background="#FF1E1F22"
                                  Foreground="#FFDDE4F0"
                                  BorderThickness="0" />
                    </TabItem>
                    <TabItem Header="Plan">
                        <TextBox x:Name="PlanTextBox" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 Background="#FF1E1F22" Foreground="#FFDDE4F0" BorderThickness="0" FontFamily="Consolas" />
                    </TabItem>
                    <TabItem Header="Improvements">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <GroupBox Grid.Column="0" Header="Recommendations" Foreground="#FFDDE4F0" BorderBrush="#FF454545" Margin="0,0,4,0">
                                <ListBox x:Name="RecommendationsListBox"
                                         DisplayMemberPath="ListLabel"
                                         SelectionChanged="RecommendationsListBox_SelectionChanged"
                                         Background="#FF1E1F22"
                                         Foreground="#FFDDE4F0"
                                         BorderThickness="0" />
                            </GroupBox>
                            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <GroupBox Header="Suggested SQL / index DDL" Foreground="#FFDDE4F0" BorderBrush="#FF454545" Margin="0,0,0,8">
                                        <TextBox x:Name="SuggestedSqlTextBox" MinHeight="80" IsReadOnly="True" TextWrapping="Wrap"
                                                 Background="#FF1E1F22" Foreground="#FFDDE4F0" BorderThickness="0" FontFamily="Consolas" />
                                    </GroupBox>
                                    <local:PlanFlowGraphControl x:Name="PlanGraphControl" MinHeight="240" Margin="0,0,0,8" />
                                    <GroupBox Header="Plan comparison (text)" Foreground="#FFDDE4F0" BorderBrush="#FF454545" Margin="0,0,0,8">
                                        <TextBox x:Name="PlanDiffTextBox" MinHeight="100" IsReadOnly="True" TextWrapping="Wrap"
                                                 Background="#FF1E1F22" Foreground="#FFDDE4F0" BorderThickness="0" FontFamily="Consolas" />
                                    </GroupBox>
                                    <GroupBox Header="pg_stat_statements (opt-in)" Foreground="#FFDDE4F0" BorderBrush="#FF454545">
                                        <TextBox x:Name="PgStatTextBox" MinHeight="80" IsReadOnly="True" TextWrapping="Wrap"
                                                 Background="#FF1E1F22" Foreground="#FFDDE4F0" BorderThickness="0" FontFamily="Consolas" />
                                    </GroupBox>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="3"
                   Margin="0,6,0,0"
                   Foreground="#FF8FA2C3"
                   Text="Tip: options.UseQueryDuckDebugging() auto-captures all queries — no WithQueryDuckScope() needed." />
    </Grid>
</UserControl>
